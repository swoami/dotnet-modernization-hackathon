@page "/upload"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Globalization
@using ContosoInsurance.Common.Storage
@using ContosoInsurance.Data
@using Microsoft.EntityFrameworkCore
@inject IConfiguration Configuration
@inject IClaimDocumentStore DocumentStore
@inject IDbContextFactory<ContosoDbContext> DbFactory
@inject ILogger<Upload> Logger

<PageTitle>Upload Claim Document</PageTitle>

<h1>Upload claim document</h1>

<p>
    <label for="claim-id">Claim ID:</label>
    <input id="claim-id" type="number" min="1" @bind="ClaimId" />
</p>
<p>
    <label for="claim-file">File:</label>
    <InputFile id="claim-file" OnChange="OnFileSelected" />
</p>
<button type="button" @onclick="UploadAsync">Upload</button>

@if (!string.IsNullOrWhiteSpace(Status))
{
    <p>@Status</p>
}

@code {
    // Blob container provisioned by infra/modules/storage.bicep for claim document uploads.
    private const string DocumentContainerName = "claim-docs";

    private int? ClaimId { get; set; }
    private IBrowserFile? selectedFile;
    private string? Status { get; set; }

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        Status = null;
    }

    private async Task UploadAsync()
    {
        if (selectedFile == null)
        {
            Status = "No file selected.";
            return;
        }

        var maxBytes = GetMaxUploadBytes();
        if (selectedFile.Size > maxBytes)
        {
            Status = "File too large.";
            return;
        }

        if (!ClaimId.HasValue || ClaimId.Value <= 0)
        {
            Status = "Invalid claim ID.";
            return;
        }

        var fileName = Path.GetFileName(selectedFile.Name);
        if (string.IsNullOrWhiteSpace(fileName))
        {
            Status = "No file selected.";
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();
        var claim = await db.Claims.SingleOrDefaultAsync(c => c.ClaimId == ClaimId.Value);
        if (claim is null)
        {
            Status = $"Claim {ClaimId.Value} not found.";
            return;
        }

        var blobName = $"{ClaimId.Value.ToString(CultureInfo.InvariantCulture)}/{fileName}";

        await using (var stream = selectedFile.OpenReadStream(maxBytes))
        {
            await DocumentStore.UploadAsync(DocumentContainerName, blobName, stream);
        }

        claim.DocumentPath = blobName;
        await db.SaveChangesAsync();

        Logger.LogInformation("Saved claim document {BlobName} for claim {ClaimId}", blobName, ClaimId.Value);
        Status = $"Uploaded {fileName} for claim {ClaimId.Value}.";
    }

    private long GetMaxUploadBytes()
    {
        return long.TryParse(Configuration["AppSettings:MaxUploadBytes"], out var configured) && configured > 0
            ? configured
            : 10 * 1024 * 1024;
    }
}
