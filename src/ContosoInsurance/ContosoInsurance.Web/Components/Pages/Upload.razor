@page "/upload"
@rendermode InteractiveServer
@using System.Globalization
@inject IConfiguration Configuration
@inject ILogger<Upload> Logger

<PageTitle>Upload Claim Document</PageTitle>

<h1>Upload claim document</h1>

<p>
    <label for="claim-id">Claim ID:</label>
    <input id="claim-id" type="number" min="1" @bind="ClaimId" />
</p>
<p>
    <label for="claim-file">File:</label>
    <InputFile id="claim-file" OnChange="OnFileSelected" />
</p>
<button type="button" @onclick="UploadAsync">Upload</button>

@if (!string.IsNullOrWhiteSpace(Status))
{
    <p>@Status</p>
}

@code {
    private int? ClaimId { get; set; }
    private IBrowserFile? selectedFile;
    private string? Status { get; set; }

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        Status = null;
    }

    private async Task UploadAsync()
    {
        if (selectedFile == null)
        {
            Status = "No file selected.";
            return;
        }

        var maxBytes = GetMaxUploadBytes();
        if (selectedFile.Size > maxBytes)
        {
            Status = "File too large.";
            return;
        }

        if (!ClaimId.HasValue || ClaimId.Value <= 0)
        {
            Status = "Invalid claim ID.";
            return;
        }

        var root = Configuration["AppSettings:ClaimDocumentsRoot"] ?? @"C:\ClaimsFiles";
        var rootFullPath = Path.GetFullPath(root);
        var fileName = Path.GetFileName(selectedFile.Name);
        if (string.IsNullOrWhiteSpace(fileName))
        {
            Status = "No file selected.";
            return;
        }

        var claimFolder = Path.Combine(rootFullPath, ClaimId.Value.ToString(CultureInfo.InvariantCulture));
        var targetFullPath = Path.GetFullPath(Path.Combine(claimFolder, fileName));
        if (!IsPathInsideRoot(targetFullPath, rootFullPath))
        {
            Status = "Invalid file path.";
            return;
        }

        Directory.CreateDirectory(claimFolder);
        await using var stream = File.Create(targetFullPath);
        await selectedFile.OpenReadStream(maxBytes).CopyToAsync(stream);

        Logger.LogInformation("Saved claim document {Path}", targetFullPath);
        Status = "Uploaded to " + targetFullPath;
    }

    private long GetMaxUploadBytes()
    {
        return long.TryParse(Configuration["AppSettings:MaxUploadBytes"], out var configured) && configured > 0
            ? configured
            : 10 * 1024 * 1024;
    }

    private static bool IsPathInsideRoot(string targetFullPath, string rootFullPath)
    {
        var normalizedRoot = rootFullPath.EndsWith(Path.DirectorySeparatorChar)
            ? rootFullPath
            : rootFullPath + Path.DirectorySeparatorChar;

        return targetFullPath.StartsWith(normalizedRoot, StringComparison.OrdinalIgnoreCase);
    }
}

