@inherits LayoutComponentBase

<div class="page">
    <header>
        <h1>Contoso Claims Portal</h1>
        <nav>
            <a href="/">Claims</a>
            <span> | </span>
            <a href="/upload">Upload</a>
            <AuthorizeView>
                <Authorized>
                    <span> | Signed in as @context.User.Identity?.Name</span>
                    <span> | </span>
                    <a href="/auth/logout">Logout</a>
                </Authorized>
            </AuthorizeView>
        </nav>
    </header>

    <main>
        @Body
    </main>
</div>
